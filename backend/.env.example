# LLM provider — set ONE of these. Groq's free tier works out of the box;
# Anthropic is the premium option. Copy this file to .env and fill in a key.
# Never commit real keys — .env is gitignored.

# Groq (https://console.groq.com) — open models, free tier
GROQ_API_KEY=gsk_...
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct   (default; most free-tier headroom)
# GROQ_REASONING_MODEL=openai/gpt-oss-120b               (used for letter reconciliation)

# Ollama — local, OpenAI-compatible, NO token limits. Used automatically as
# the final fallback when the Groq free tiers are exhausted, or as the sole
# provider with LLM_PROVIDER=ollama. Set OLLAMA_MODEL to your `ollama list` tag.
# OLLAMA_MODEL=gemma4:e4b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# USE_OLLAMA_FALLBACK=true

# Anthropic (https://console.anthropic.com) — alternative provider
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# Force a provider explicitly: groq (default) | ollama | anthropic
# LLM_PROVIDER=ollama
